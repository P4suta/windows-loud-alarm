<Window
    x:Class="Alarm.Presentation.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    xmlns:behaviors="using:Alarm.Presentation.Behaviors"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Loaded="OnRootLoaded">
        <Grid.Resources>
            <CubicEase x:Key="EaseOutCubic" EasingMode="EaseOut"/>
            <CubicEase x:Key="EaseInOutCubic" EasingMode="EaseInOut"/>
            <BackEase x:Key="EaseOutBack" EasingMode="EaseOut" Amplitude="0.4"/>
            <QuinticEase x:Key="EaseOutQuint" EasingMode="EaseOut"/>
            <!-- Used by rollback storyboards. Pairs with the Bezier(0.16,1 0.3,1) of the
                 progress storyboard: forward is "fast then snap into end", reverse is the
                 mirror — a quintic ease-in approximates it well enough to feel like the
                 forward animation playing back in reverse. -->
            <QuinticEase x:Key="EaseInQuint" EasingMode="EaseIn"/>

            <!-- Long-press progress. Uses SplineDoubleKeyFrame with the same Bezier
                 (0.075, 0.82, 0.165, 1) as the Composition inversion clip, so the
                 black-text reveal stays pixel-perfectly synced with the white bar. -->
            <Storyboard x:Name="ArmProgressStoryboard">
                <DoubleAnimationUsingKeyFrames x:Name="ArmFillFrames"
                                                Storyboard.TargetName="ArmFillScale"
                                                Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                    <SplineDoubleKeyFrame KeyTime="0:0:1.6" Value="1"
                                          KeySpline="0.16,1 0.3,1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames x:Name="IdleTextScaleXFrames"
                                                Storyboard.TargetName="IdleTextScale"
                                                Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                    <SplineDoubleKeyFrame KeyTime="0:0:1.6" Value="0.94"
                                          KeySpline="0.16,1 0.3,1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames x:Name="IdleTextScaleYFrames"
                                                Storyboard.TargetName="IdleTextScale"
                                                Storyboard.TargetProperty="ScaleY">
                    <SplineDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                    <SplineDoubleKeyFrame KeyTime="0:0:1.6" Value="0.94"
                                          KeySpline="0.16,1 0.3,1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames x:Name="IdleInvertedTextScaleXFrames"
                                                Storyboard.TargetName="IdleInvertedTextScale"
                                                Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                    <SplineDoubleKeyFrame KeyTime="0:0:1.6" Value="0.94"
                                          KeySpline="0.16,1 0.3,1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames x:Name="IdleInvertedTextScaleYFrames"
                                                Storyboard.TargetName="IdleInvertedTextScale"
                                                Storyboard.TargetProperty="ScaleY">
                    <SplineDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                    <SplineDoubleKeyFrame KeyTime="0:0:1.6" Value="0.94"
                                          KeySpline="0.16,1 0.3,1"/>
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>

            <!-- Rollback = "reverse playback" of the progress storyboard. No From= so the
                 animation starts from wherever the progress storyboard happened to be when
                 the press was released, and "hyu〜n"s smoothly back to the idle pose. -->
            <Storyboard x:Name="ArmRollbackStoryboard">
                <DoubleAnimation Storyboard.TargetName="ArmFillScale"
                                 Storyboard.TargetProperty="ScaleX"
                                 To="0" Duration="0:0:0.6"
                                 EasingFunction="{StaticResource EaseInQuint}"/>
                <DoubleAnimation Storyboard.TargetName="IdleTextScale"
                                 Storyboard.TargetProperty="ScaleX"
                                 To="1" Duration="0:0:0.6"
                                 EasingFunction="{StaticResource EaseInQuint}"/>
                <DoubleAnimation Storyboard.TargetName="IdleTextScale"
                                 Storyboard.TargetProperty="ScaleY"
                                 To="1" Duration="0:0:0.6"
                                 EasingFunction="{StaticResource EaseInQuint}"/>
                <DoubleAnimation Storyboard.TargetName="IdleInvertedTextScale"
                                 Storyboard.TargetProperty="ScaleX"
                                 To="1" Duration="0:0:0.6"
                                 EasingFunction="{StaticResource EaseInQuint}"/>
                <DoubleAnimation Storyboard.TargetName="IdleInvertedTextScale"
                                 Storyboard.TargetProperty="ScaleY"
                                 To="1" Duration="0:0:0.6"
                                 EasingFunction="{StaticResource EaseInQuint}"/>
            </Storyboard>

            <Storyboard x:Name="CancelProgressStoryboard">
                <DoubleAnimationUsingKeyFrames x:Name="CancelFillFrames"
                                                Storyboard.TargetName="CancelFillScale"
                                                Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                    <SplineDoubleKeyFrame KeyTime="0:0:1.6" Value="1"
                                          KeySpline="0.16,1 0.3,1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames x:Name="ArmedTextScaleXFrames"
                                                Storyboard.TargetName="ArmedTextScale"
                                                Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                    <SplineDoubleKeyFrame KeyTime="0:0:1.6" Value="0.94"
                                          KeySpline="0.16,1 0.3,1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames x:Name="ArmedTextScaleYFrames"
                                                Storyboard.TargetName="ArmedTextScale"
                                                Storyboard.TargetProperty="ScaleY">
                    <SplineDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                    <SplineDoubleKeyFrame KeyTime="0:0:1.6" Value="0.94"
                                          KeySpline="0.16,1 0.3,1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames x:Name="ArmedInvertedTextScaleXFrames"
                                                Storyboard.TargetName="ArmedInvertedTextScale"
                                                Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                    <SplineDoubleKeyFrame KeyTime="0:0:1.6" Value="0.94"
                                          KeySpline="0.16,1 0.3,1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames x:Name="ArmedInvertedTextScaleYFrames"
                                                Storyboard.TargetName="ArmedInvertedTextScale"
                                                Storyboard.TargetProperty="ScaleY">
                    <SplineDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                    <SplineDoubleKeyFrame KeyTime="0:0:1.6" Value="0.94"
                                          KeySpline="0.16,1 0.3,1"/>
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>

            <Storyboard x:Name="CancelRollbackStoryboard">
                <DoubleAnimation Storyboard.TargetName="CancelFillScale"
                                 Storyboard.TargetProperty="ScaleX"
                                 To="0" Duration="0:0:0.6"
                                 EasingFunction="{StaticResource EaseInQuint}"/>
                <DoubleAnimation Storyboard.TargetName="ArmedTextScale"
                                 Storyboard.TargetProperty="ScaleX"
                                 To="1" Duration="0:0:0.6"
                                 EasingFunction="{StaticResource EaseInQuint}"/>
                <DoubleAnimation Storyboard.TargetName="ArmedTextScale"
                                 Storyboard.TargetProperty="ScaleY"
                                 To="1" Duration="0:0:0.6"
                                 EasingFunction="{StaticResource EaseInQuint}"/>
                <DoubleAnimation Storyboard.TargetName="ArmedInvertedTextScale"
                                 Storyboard.TargetProperty="ScaleX"
                                 To="1" Duration="0:0:0.6"
                                 EasingFunction="{StaticResource EaseInQuint}"/>
                <DoubleAnimation Storyboard.TargetName="ArmedInvertedTextScale"
                                 Storyboard.TargetProperty="ScaleY"
                                 To="1" Duration="0:0:0.6"
                                 EasingFunction="{StaticResource EaseInQuint}"/>
            </Storyboard>

            <!-- Exit storyboards animate both the Panel AND the per-cycle bar fill back to zero,
                 so a single FillBehavior=HoldEnd Filling state covers the entire "panel hidden"
                 invariant. No external direct set / Storyboard.Stop() needed afterwards. -->
            <Storyboard x:Name="IdleExitStoryboard" Completed="OnIdleExitCompleted">
                <DoubleAnimation Storyboard.TargetName="IdleTranslate" Storyboard.TargetProperty="X"
                                 From="0" To="-260" Duration="0:0:0.38"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation Storyboard.TargetName="IdleScale" Storyboard.TargetProperty="ScaleX"
                                 To="0.88" Duration="0:0:0.38"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation Storyboard.TargetName="IdleScale" Storyboard.TargetProperty="ScaleY"
                                 To="0.88" Duration="0:0:0.38"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation Storyboard.TargetName="IdlePanel" Storyboard.TargetProperty="Opacity"
                                 From="1" To="0" Duration="0:0:0.3"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <!-- Collapse the long-press bar in lockstep with the panel leaving. -->
                <DoubleAnimation Storyboard.TargetName="ArmFillScale" Storyboard.TargetProperty="ScaleX"
                                 To="0" Duration="0:0:0.38"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
            </Storyboard>

            <Storyboard x:Name="IdleEnterStoryboard">
                <DoubleAnimation Storyboard.TargetName="IdleTranslate" Storyboard.TargetProperty="X"
                                 From="-260" To="0" Duration="0:0:0.55"
                                 EasingFunction="{StaticResource EaseOutBack}"/>
                <DoubleAnimation Storyboard.TargetName="IdleScale" Storyboard.TargetProperty="ScaleX"
                                 From="0.88" To="1" Duration="0:0:0.55"
                                 EasingFunction="{StaticResource EaseOutBack}"/>
                <DoubleAnimation Storyboard.TargetName="IdleScale" Storyboard.TargetProperty="ScaleY"
                                 From="0.88" To="1" Duration="0:0:0.55"
                                 EasingFunction="{StaticResource EaseOutBack}"/>
                <DoubleAnimation Storyboard.TargetName="IdlePanel" Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="0:0:0.5"
                                 EasingFunction="{StaticResource EaseOutCubic}"/>
            </Storyboard>

            <Storyboard x:Name="ArmedExitStoryboard" Completed="OnArmedExitCompleted">
                <DoubleAnimation Storyboard.TargetName="ArmedTranslate" Storyboard.TargetProperty="X"
                                 From="0" To="260" Duration="0:0:0.38"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation Storyboard.TargetName="ArmedScale" Storyboard.TargetProperty="ScaleX"
                                 To="0.88" Duration="0:0:0.38"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation Storyboard.TargetName="ArmedScale" Storyboard.TargetProperty="ScaleY"
                                 To="0.88" Duration="0:0:0.38"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation Storyboard.TargetName="ArmedPanel" Storyboard.TargetProperty="Opacity"
                                 From="1" To="0" Duration="0:0:0.3"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <!-- Collapse the long-press bar in lockstep with the panel leaving. -->
                <DoubleAnimation Storyboard.TargetName="CancelFillScale" Storyboard.TargetProperty="ScaleX"
                                 To="0" Duration="0:0:0.38"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
            </Storyboard>

            <Storyboard x:Name="ArmedEnterStoryboard">
                <DoubleAnimation Storyboard.TargetName="ArmedTranslate" Storyboard.TargetProperty="X"
                                 From="260" To="0" Duration="0:0:0.55"
                                 EasingFunction="{StaticResource EaseOutBack}"/>
                <DoubleAnimation Storyboard.TargetName="ArmedScale" Storyboard.TargetProperty="ScaleX"
                                 From="1.12" To="1" Duration="0:0:0.55"
                                 EasingFunction="{StaticResource EaseOutBack}"/>
                <DoubleAnimation Storyboard.TargetName="ArmedScale" Storyboard.TargetProperty="ScaleY"
                                 From="1.12" To="1" Duration="0:0:0.55"
                                 EasingFunction="{StaticResource EaseOutBack}"/>
                <DoubleAnimation Storyboard.TargetName="ArmedPanel" Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="0:0:0.5"
                                 EasingFunction="{StaticResource EaseOutCubic}"/>
            </Storyboard>

            <!-- Hover text swap: a single conveyor motion. CANCEL and Normal move the
                 SAME distance in the same direction, with the spacing between them set
                 to exactly (Cancel.Width + Normal.Width) / 2 so CANCEL's right edge sits
                 against Normal's left edge throughout the slide. The X To= placeholders
                 are rewritten from MainWindow.xaml.cs the moment text widths are known. -->
            <Storyboard x:Name="CancelTextEnterStoryboard">
                <DoubleAnimation x:Name="EnterNormalXAnim"
                                 Storyboard.TargetName="ArmedNormalTranslate" Storyboard.TargetProperty="X"
                                 Duration="0:0:0.42"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation Storyboard.TargetName="ArmedNormalText" Storyboard.TargetProperty="Opacity"
                                 To="0" Duration="0:0:0.42"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation x:Name="EnterCancelXAnim"
                                 Storyboard.TargetName="ArmedCancelTranslate" Storyboard.TargetProperty="X"
                                 To="0" Duration="0:0:0.42"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation Storyboard.TargetName="ArmedCancelText" Storyboard.TargetProperty="Opacity"
                                 To="1" Duration="0:0:0.42"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <!-- Inverted layer mirror -->
                <DoubleAnimation x:Name="EnterInvertedNormalXAnim"
                                 Storyboard.TargetName="ArmedInvertedNormalTranslate" Storyboard.TargetProperty="X"
                                 Duration="0:0:0.42"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation Storyboard.TargetName="ArmedInvertedNormalText" Storyboard.TargetProperty="Opacity"
                                 To="0" Duration="0:0:0.42"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation x:Name="EnterInvertedCancelXAnim"
                                 Storyboard.TargetName="ArmedInvertedCancelTranslate" Storyboard.TargetProperty="X"
                                 To="0" Duration="0:0:0.42"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation Storyboard.TargetName="ArmedInvertedCancelText" Storyboard.TargetProperty="Opacity"
                                 To="1" Duration="0:0:0.42"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
            </Storyboard>

            <!-- Exit is the exact reverse of Enter — same conveyor, reversed direction.
                 FillBehavior=Stop releases the animated values on completion so the source
                 X=0 wins; OnCancelTextExitCompleted then re-seats the dynamic conveyor offset. -->
            <Storyboard x:Name="CancelTextExitStoryboard"
                        FillBehavior="Stop"
                        Completed="OnCancelTextExitCompleted">
                <DoubleAnimation x:Name="ExitCancelXAnim"
                                 Storyboard.TargetName="ArmedCancelTranslate" Storyboard.TargetProperty="X"
                                 Duration="0:0:0.42"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation Storyboard.TargetName="ArmedCancelText" Storyboard.TargetProperty="Opacity"
                                 To="0" Duration="0:0:0.42"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation x:Name="ExitNormalXAnim"
                                 Storyboard.TargetName="ArmedNormalTranslate" Storyboard.TargetProperty="X"
                                 To="0" Duration="0:0:0.42"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation Storyboard.TargetName="ArmedNormalText" Storyboard.TargetProperty="Opacity"
                                 To="1" Duration="0:0:0.42"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <!-- Inverted layer mirror -->
                <DoubleAnimation x:Name="ExitInvertedCancelXAnim"
                                 Storyboard.TargetName="ArmedInvertedCancelTranslate" Storyboard.TargetProperty="X"
                                 Duration="0:0:0.42"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation Storyboard.TargetName="ArmedInvertedCancelText" Storyboard.TargetProperty="Opacity"
                                 To="0" Duration="0:0:0.42"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation x:Name="ExitInvertedNormalXAnim"
                                 Storyboard.TargetName="ArmedInvertedNormalTranslate" Storyboard.TargetProperty="X"
                                 To="0" Duration="0:0:0.42"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation Storyboard.TargetName="ArmedInvertedNormalText" Storyboard.TargetProperty="Opacity"
                                 To="1" Duration="0:0:0.42"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
            </Storyboard>

            <Storyboard x:Name="TimePulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
                <DoubleAnimation Storyboard.TargetName="TimeButton"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.55" To="1.0" Duration="0:0:1.8"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
            </Storyboard>

            <Storyboard x:Name="RingingPulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
                <DoubleAnimation Storyboard.TargetName="RingingAlarmScale"
                                 Storyboard.TargetProperty="ScaleX"
                                 From="1.0" To="1.08" Duration="0:0:0.7"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation Storyboard.TargetName="RingingAlarmScale"
                                 Storyboard.TargetProperty="ScaleY"
                                 From="1.0" To="1.08" Duration="0:0:0.7"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
                <DoubleAnimation Storyboard.TargetName="RingingAlarmText"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.7" To="1.0" Duration="0:0:0.7"
                                 EasingFunction="{StaticResource EaseInOutCubic}"/>
            </Storyboard>

            <Storyboard x:Name="GearRotateInStoryboard">
                <DoubleAnimation Storyboard.TargetName="GearRotate"
                                 Storyboard.TargetProperty="Angle"
                                 To="90" Duration="0:0:0.35"
                                 EasingFunction="{StaticResource EaseOutQuint}"/>
                <DoubleAnimation Storyboard.TargetName="SettingsButton"
                                 Storyboard.TargetProperty="Opacity"
                                 To="1.0" Duration="0:0:0.2"/>
            </Storyboard>
            <Storyboard x:Name="GearRotateOutStoryboard">
                <DoubleAnimation Storyboard.TargetName="GearRotate"
                                 Storyboard.TargetProperty="Angle"
                                 To="0" Duration="0:0:0.45"
                                 EasingFunction="{StaticResource EaseOutQuint}"/>
                <DoubleAnimation Storyboard.TargetName="SettingsButton"
                                 Storyboard.TargetProperty="Opacity"
                                 To="0.55" Duration="0:0:0.3"/>
            </Storyboard>
        </Grid.Resources>

        <!-- ============ IDLE ============ -->
        <Grid x:Name="IdlePanel" RenderTransformOrigin="0.5,0.5"
              Visibility="{x:Bind VisibleWhenIdle(ViewModel.IsArmed, ViewModel.IsRinging), Mode=OneWay}">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="IdleScale" ScaleX="1" ScaleY="1"/>
                    <TranslateTransform x:Name="IdleTranslate" X="0"/>
                </TransformGroup>
            </Grid.RenderTransform>

            <Grid x:Name="ArmGestureHost" Background="Transparent">
                <i:Interaction.Behaviors>
                    <behaviors:LongPressGestureBehavior
                        x:Name="ArmGesture"
                        Duration="0:0:1.6"
                        RollbackDuration="0:0:0.6"
                        ProgressStoryboard="{StaticResource ArmProgressStoryboard}"
                        RollbackStoryboard="{StaticResource ArmRollbackStoryboard}"
                        Pressed="OnArmGesturePressed"
                        Confirmed="OnArmConfirmed"/>
                </i:Interaction.Behaviors>
                <!-- z=0: Black progress fill. ArmFillScale.ScaleX (0→1) grows from left to right. -->
                <Rectangle x:Name="ArmFillRect"
                           Fill="Black"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           RenderTransformOrigin="0,0.5">
                    <Rectangle.RenderTransform>
                        <ScaleTransform x:Name="ArmFillScale" ScaleX="0" ScaleY="1"/>
                    </Rectangle.RenderTransform>
                </Rectangle>

                <!-- z=1: Normal text (theme primary, hit-testable). Always fully visible. -->
                <Viewbox Stretch="Uniform" Margin="48"
                         RenderTransformOrigin="0.5,0.5">
                    <Viewbox.RenderTransform>
                        <ScaleTransform x:Name="IdleTextScale" ScaleX="1" ScaleY="1"/>
                    </Viewbox.RenderTransform>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="WAKE ME AT "
                                   FontFamily="ms-appx:///Assets/Fonts/Geist.ttf#Geist"
                                   FontSize="64" FontWeight="Light"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="TimeButton"
                                Background="Transparent" BorderThickness="0"
                                Padding="4,0" MinHeight="0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind ViewModel.AlarmTimeDisplay, Mode=OneWay}"
                                       FontSize="64" FontWeight="SemiBold"
                                       FontFamily="ms-appx:///Assets/Fonts/GeistMono.ttf#Geist Mono"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <TimePicker SelectedTime="{x:Bind ViewModel.AlarmTimeBindable, Mode=TwoWay}"
                                                ClockIdentifier="24HourClock"/>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <TextBlock Text="."
                                   FontFamily="ms-appx:///Assets/Fonts/Geist.ttf#Geist"
                                   FontSize="64" FontWeight="Light"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Viewbox>

                <!-- z=2 (top): Inverted (white) text layer. Identical content to the normal
                     layer, but clipped on the right to show only the portion that overlaps
                     the black bar. MainWindow.xaml.cs binds the clip's Rect.Width to
                     ArmGestureHost.ActualWidth * ArmFillScale.ScaleX, so the inversion stays
                     pixel-perfectly aligned with the bar at every frame. -->
                <Grid x:Name="IdleInvertedLayer" IsHitTestVisible="False">
                    <Grid.Clip>
                        <RectangleGeometry x:Name="IdleInvertedClip" Rect="0,0,0,0"/>
                    </Grid.Clip>
                    <Viewbox Stretch="Uniform" Margin="48"
                             RenderTransformOrigin="0.5,0.5">
                        <Viewbox.RenderTransform>
                            <ScaleTransform x:Name="IdleInvertedTextScale" ScaleX="1" ScaleY="1"/>
                        </Viewbox.RenderTransform>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="WAKE ME AT "
                                       FontFamily="ms-appx:///Assets/Fonts/Geist.ttf#Geist"
                                       FontSize="64" FontWeight="Light"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.AlarmTimeDisplay, Mode=OneWay}"
                                       FontFamily="ms-appx:///Assets/Fonts/GeistMono.ttf#Geist Mono"
                                       FontSize="64" FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="4,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="."
                                       FontFamily="ms-appx:///Assets/Fonts/Geist.ttf#Geist"
                                       FontSize="64" FontWeight="Light"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Viewbox>
                </Grid>
            </Grid>
        </Grid>

        <!-- ============ ARMED ============ -->
        <Grid x:Name="ArmedPanel" RenderTransformOrigin="0.5,0.5"
              Visibility="{x:Bind VisibleWhenArmed(ViewModel.IsArmed, ViewModel.IsRinging), Mode=OneWay}">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="ArmedScale" ScaleX="1" ScaleY="1"/>
                    <TranslateTransform x:Name="ArmedTranslate" X="0"/>
                </TransformGroup>
            </Grid.RenderTransform>

            <Grid x:Name="CountdownHost" Background="Transparent">
                <!-- White progress fill -->
                <Rectangle x:Name="CancelFillRect"
                           Fill="Black"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           RenderTransformOrigin="0,0.5">
                    <Rectangle.RenderTransform>
                        <ScaleTransform x:Name="CancelFillScale" ScaleX="0" ScaleY="1"/>
                    </Rectangle.RenderTransform>
                </Rectangle>

                <!-- z=1: Normal text layer for Armed (hit-testable). -->
                <Viewbox Stretch="Uniform" Margin="48"
                         PointerEntered="OnCountdownEntered"
                         PointerExited="OnCountdownExited"
                         RenderTransformOrigin="0.5,0.5">
                    <i:Interaction.Behaviors>
                        <behaviors:LongPressGestureBehavior
                            x:Name="CancelGesture"
                            Duration="0:0:1.6"
                            RollbackDuration="0:0:0.6"
                            ProgressStoryboard="{StaticResource CancelProgressStoryboard}"
                            RollbackStoryboard="{StaticResource CancelRollbackStoryboard}"
                            Pressed="OnCancelGesturePressed"
                            Confirmed="OnCancelConfirmed"/>
                    </i:Interaction.Behaviors>
                    <Viewbox.RenderTransform>
                        <ScaleTransform x:Name="ArmedTextScale" ScaleX="1" ScaleY="1"/>
                    </Viewbox.RenderTransform>
                    <Grid Background="Transparent">
                        <StackPanel x:Name="ArmedNormalText"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Opacity="1"
                                    SizeChanged="OnArmedTextSizeChanged">
                            <StackPanel.RenderTransform>
                                <TranslateTransform x:Name="ArmedNormalTranslate" X="0"/>
                            </StackPanel.RenderTransform>
                            <TextBlock Text="WAKING YOU AT "
                                       FontFamily="ms-appx:///Assets/Fonts/Geist.ttf#Geist"
                                       FontSize="56" FontWeight="Light"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.AlarmTimeDisplay, Mode=OneWay}"
                                       FontFamily="ms-appx:///Assets/Fonts/GeistMono.ttf#Geist Mono"
                                       FontSize="56" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       Margin="4,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="."
                                       FontFamily="ms-appx:///Assets/Fonts/Geist.ttf#Geist"
                                       FontSize="56" FontWeight="Light"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="ArmedCancelText"
                                   Text="CANCEL"
                                   FontFamily="ms-appx:///Assets/Fonts/Geist.ttf#Geist"
                                   FontSize="56" FontWeight="Light"
                                   Foreground="#FFE53935"
                                   CharacterSpacing="100"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   SizeChanged="OnArmedTextSizeChanged"
                                   Opacity="0">
                            <TextBlock.RenderTransform>
                                <!-- Initial X is overwritten in OnArmedTextSizeChanged once
                                     ActualWidth is known, so the magnitude matches the texts. -->
                                <TranslateTransform x:Name="ArmedCancelTranslate" X="0"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Grid>
                </Viewbox>

                <!-- z=2 (top): Inverted (white) text layer for Armed. Clipped to the bar's
                     extent so the inversion stays exactly where the black bar has filled. -->
                <Grid x:Name="ArmedInvertedLayer" IsHitTestVisible="False">
                    <Grid.Clip>
                        <RectangleGeometry x:Name="ArmedInvertedClip" Rect="0,0,0,0"/>
                    </Grid.Clip>
                    <Viewbox Stretch="Uniform" Margin="48"
                             RenderTransformOrigin="0.5,0.5">
                        <Viewbox.RenderTransform>
                            <ScaleTransform x:Name="ArmedInvertedTextScale" ScaleX="1" ScaleY="1"/>
                        </Viewbox.RenderTransform>
                        <Grid Background="Transparent">
                            <StackPanel x:Name="ArmedInvertedNormalText"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Opacity="1">
                                <StackPanel.RenderTransform>
                                    <TranslateTransform x:Name="ArmedInvertedNormalTranslate" X="0"/>
                                </StackPanel.RenderTransform>
                                <TextBlock Text="WAKING YOU AT "
                                           FontFamily="ms-appx:///Assets/Fonts/Geist.ttf#Geist"
                                           FontSize="56" FontWeight="Light"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind ViewModel.AlarmTimeDisplay, Mode=OneWay}"
                                           FontFamily="ms-appx:///Assets/Fonts/GeistMono.ttf#Geist Mono"
                                           FontSize="56" FontWeight="SemiBold"
                                           Foreground="White"
                                           Margin="4,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="."
                                           FontFamily="ms-appx:///Assets/Fonts/Geist.ttf#Geist"
                                           FontSize="56" FontWeight="Light"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="ArmedInvertedCancelText"
                                       Text="CANCEL"
                                       FontFamily="ms-appx:///Assets/Fonts/Geist.ttf#Geist"
                                       FontSize="56" FontWeight="Light"
                                       Foreground="White"
                                       CharacterSpacing="100"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Opacity="0">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="ArmedInvertedCancelTranslate" X="0"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </Viewbox>
                </Grid>
            </Grid>
        </Grid>

        <!-- ============ RINGING ============ -->
        <Border Background="{ThemeResource SystemControlAcrylicWindowBrush}"
                Visibility="{x:Bind VisibleWhenTrue(ViewModel.IsRinging), Mode=OneWay}">
            <Grid Padding="32">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                    <TextBlock x:Name="RingingAlarmText"
                               Text="ALARM"
                               FontFamily="ms-appx:///Assets/Fonts/Geist.ttf#Geist"
                               FontSize="96" FontWeight="Light"
                               Foreground="#FFE53935"
                               HorizontalAlignment="Center"
                               CharacterSpacing="100"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <ScaleTransform x:Name="RingingAlarmScale" ScaleX="1" ScaleY="1"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock Text="W A K E   U P"
                               FontFamily="ms-appx:///Assets/Fonts/Geist.ttf#Geist"
                               FontSize="20" FontWeight="Light"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               CharacterSpacing="400"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{x:Bind ViewModel.RingingFireAtDisplay, Mode=OneWay}"
                               FontFamily="ms-appx:///Assets/Fonts/GeistMono.ttf#Geist Mono"
                               FontSize="48" FontWeight="SemiBold"
                               Opacity="0.7"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"/>
                    <Button Content="STOP"
                            FontFamily="ms-appx:///Assets/Fonts/Geist.ttf#Geist"
                            FontSize="32" FontWeight="SemiBold"
                            MinHeight="80" MinWidth="280"
                            Padding="48,16" Margin="0,24,0,0"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.StopRingingCommand}"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ SETTINGS ============ -->
        <Button x:Name="SettingsButton"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,12,16,0" Padding="8"
                Background="Transparent" BorderThickness="0"
                Opacity="0.55"
                Canvas.ZIndex="100"
                PointerEntered="OnSettingsEntered"
                PointerExited="OnSettingsExited"
                RenderTransformOrigin="0.5,0.5">
            <Button.RenderTransform>
                <RotateTransform x:Name="GearRotate" Angle="0"/>
            </Button.RenderTransform>
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE713;" FontSize="20"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Button.Flyout>
                <Flyout Placement="BottomEdgeAlignedRight">
                    <StackPanel Spacing="12" MinWidth="280">
                        <TextBlock Text="SOUND"
                                   FontFamily="ms-appx:///Assets/Fonts/Geist.ttf#Geist"
                                   CharacterSpacing="100"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.SoundDisplay, Mode=OneWay}"
                                   FontFamily="ms-appx:///Assets/Fonts/Geist.ttf#Geist"
                                   TextTrimming="CharacterEllipsis"/>
                        <Button Content="Browse…"
                                Command="{x:Bind ViewModel.PickFileCommand}"
                                HorizontalAlignment="Stretch"/>
                        <HyperlinkButton Content="Reset to Windows default"
                                         Command="{x:Bind ViewModel.UseSystemDefaultCommand}"
                                         FontSize="11"
                                         Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                         HorizontalAlignment="Right"/>
                    </StackPanel>
                </Flyout>
            </Button.Flyout>
        </Button>
    </Grid>
</Window>
